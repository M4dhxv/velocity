PORT=3000

# Google Cloud key enabled for Speech-to-Text + Text-to-Speech
GOOGLE_API_KEY=

# Google Maps Geocoding key for city/country detection
# Optional if GOOGLE_API_KEY is also enabled for Geocoding API.
GOOGLE_MAPS_API_KEY=

# Gemini key for profile extraction
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Supabase server-side credentials
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Apify job ingestion
APIFY_TOKEN=
# Optional token pool (comma/newline separated). Pipeline auto-fails-over on quota errors.
# APIFY_TOKENS=token_a,token_b,token_c
APIFY_UPWORK_ACTOR_ID=
APIFY_LINKEDIN_ACTOR_ID=

# Import from existing Apify storage instead of launching new runs.
# APIFY_USE_STORED_RUNS=true
# APIFY_UPWORK_DATASET_IDS=dataset_id_1,dataset_id_2
# APIFY_LINKEDIN_DATASET_IDS=dataset_id_3

# Optional JSON inputs passed to actors
# APIFY_UPWORK_INPUT={"query":"react"}
# APIFY_LINKEDIN_INPUT={"query":"frontend"}

# Optional Upwork multi-target extraction list.
# If omitted, built-in defaults are used.
# APIFY_UPWORK_TARGETS=[{"query":"frontend developer","limit":20},{"query":"react developer","limit":20}]

# Optional actor field mapping for query + limit
APIFY_UPWORK_QUERY_FIELD=query
APIFY_UPWORK_LIMIT_FIELD=maxItems

# Protect cron/manual ingestion endpoint
CRON_SECRET=
